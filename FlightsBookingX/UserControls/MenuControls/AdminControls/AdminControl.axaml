                                                </Border>

                                                <StackPanel Grid.Column="1" Margin="20,0" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Name}"
                                                               FontSize="18"
                                                               FontWeight="Bold" />
                                                </StackPanel>

                                                <StackPanel Grid.Column="2" VerticalAlignment="Center"
                                                            Margin="0,0,20,0">
                                                    <TextBlock Text="ID ГОРОДА"
                                                               FontSize="10"
                                                               FontWeight="SemiBold"
                                                               Foreground="{DynamicResource TextSecondary}"
                                                               HorizontalAlignment="Right" />
                                                    <TextBlock Text="{Binding Id, StringFormat='{}#{0}'}"
                                                               FontSize="18"
                                                               FontWeight="Bold"
                                                               Foreground="{DynamicResource BrandDark}"
                                                               HorizontalAlignment="Right" />
                                                </StackPanel>

                                                <Border Grid.Column="3" Margin="10,0,0,0" Padding="20,0,0,0"
                                                        BorderBrush="{DynamicResource BgInput}"
                                                        BorderThickness="1,0,0,0">
                                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                                                                Spacing="8">
                                                        <Button Classes="Outline"
                                                                Width="38" Height="38" Padding="0"
                                                                ToolTip.Tip="Изменить название"
                                                                Tag="{Binding}">
                                                            <PathIcon
                                                                Data="M20.71,7.04C21.1,6.65 21.1,6 20.71,5.63L18.37,3.29C18,2.9 17.35,2.9 16.96,3.29L15.12,5.12L18.87,8.87M3,17.25V21H6.75L17.81,9.93L14.06,6.18L3,17.25Z"
                                                                Width="16" Height="16" />
                                                        </Button>
                                                        <Button Classes="Outline"
                                                                Width="38" Height="38" Padding="0"
                                                                Foreground="#EF4444"
                                                                ToolTip.Tip="Удалить город"
                                                                Tag="{Binding}">
                                                            <PathIcon
                                                                Data="M19,4H15.5L14.5,3H9.5L8.5,4H5V6H19V4M6,19A2,2 0 0,0 8,21H16A2,2 0 0,0 18,19V7H6V19Z"
                                                                Width="16" Height="16" />
                                                        </Button>
                                                    </StackPanel>
                                                </Border>

                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>

    </Grid>
</UserControl>