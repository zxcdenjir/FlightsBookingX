                    </Border>
                    <Border Grid.Row="1" Margin="30" CornerRadius="20" ClipToBounds="True"
                            Background="{DynamicResource BgInput}">
                        <ScrollViewer>
                            <ItemsControl Name="CountriesControl" Padding="10">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Spacing="10" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="models:Country">
                                        <Border Background="{DynamicResource BgCard}"
                                                CornerRadius="12"
                                                Padding="20"
                                                BoxShadow="0 2 5 0 #05000000">
