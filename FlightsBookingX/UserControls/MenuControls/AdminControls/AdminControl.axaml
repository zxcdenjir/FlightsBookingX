                                                <Border Grid.Column="0"
                                                        Width="50" Height="50"
                                                        CornerRadius="10"
                                                        Background="{DynamicResource BgInput}"
                                                        VerticalAlignment="Center">
                                                    <PathIcon
                                                        Data="M12,2C6.48,2 2,6.48 2,12C2,17.52 6.48,22 12,22C17.52,22 22,17.52 22,12C22,6.48 17.52,2 12,2M11,19.93C7.05,19.44 4,16.08 4,12C4,11.38 4.08,10.78 4.21,10.21L9,15V16A2,2 0 0,0 11,18V19.93M17.9,17.39C17.64,16.58 17,16 16,16H15V13A1,1 0 0,0 14,12H8V10H10A1,1 0 0,0 11,9V7H13A2,2 0 0,0 15,5V4.59C18.55,5.78 21,9.11 21,13C21,14.63 20.45,16.14 19.5,17.34L17.9,17.39Z"
