                                                               FontSize="18"
                                                               FontWeight="Bold" />
                                                </StackPanel>

                                                <StackPanel Grid.Column="2" VerticalAlignment="Center"
                                                            Margin="0,0,20,0">
                                                    <TextBlock Text="ID СТРАНЫ"
                                                               FontSize="10"
                                                               FontWeight="SemiBold"
                                                               Foreground="{DynamicResource TextSecondary}"
                                                               HorizontalAlignment="Right" />
                                                    <TextBlock Text="{Binding Id, StringFormat='{}#{0}'}"
                                                               FontSize="18"
                                                               FontWeight="Bold"
                                                               Foreground="{DynamicResource BrandDark}"
                                                               HorizontalAlignment="Right" />
                                                </StackPanel>

                                                <Border Grid.Column="3" Margin="10,0,0,0" Padding="20,0,0,0"
                                                        BorderBrush="{DynamicResource BgInput}"
                                                        BorderThickness="1,0,0,0">
                                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                                                                Spacing="8">
                                                        <Button Classes="Outline"
                                                                Width="38" Height="38" Padding="0"
                                                                ToolTip.Tip="Редактировать название"
                                                                Tag="{Binding}">
                                                            <PathIcon
                                                                Data="M20.71,7.04C21.1,6.65 21.1,6 20.71,5.63L18.37,3.29C18,2.9 17.35,2.9 16.96,3.29L15.12,5.12L18.87,8.87M3,17.25V21H6.75L17.81,9.93L14.06,6.18L3,17.25Z"
                                                                Width="16" Height="16" />
                                                        </Button>
                                                        <Button Classes="Outline"
                                                                Width="38" Height="38" Padding="0"
                                                                Foreground="#EF4444"
                                                                ToolTip.Tip="Удалить страну"
                                                                Tag="{Binding}">
                                                            <PathIcon
                                                                Data="M19,4H15.5L14.5,3H9.5L8.5,4H5V6H19V4M6,19A2,2 0 0,0 8,21H16A2,2 0 0,0 18,19V7H6V19Z"
                                                                Width="16" Height="16" />
                                                        </Button>
                                                    </StackPanel>
                                                </Border>

                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Города">
                <Grid RowDefinitions="Auto, *">
                    <Border Grid.Row="0" Margin="30 30 30 0" Background="{DynamicResource BgCard}" Padding="25"
                            CornerRadius="12"
                            BoxShadow="0 2 8 0 #08000000">
                        <Grid ColumnDefinitions="*,*,*,*">
                            <TextBlock Grid.Column="0" Name="TotalCitiesBlock" Classes="label" FontSize="20"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                            <Button
                                Grid.Column="3"
                                Classes="Primary"
                                Content="Добавить город"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Padding="15 10" />
                        </Grid>
                    </Border>
                    <Border Grid.Row="1" Margin="30" CornerRadius="20" ClipToBounds="True"
                            Background="{DynamicResource BgInput}">
                        <ScrollViewer>
                            <ItemsControl Name="CitiesControl" Padding="10">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Spacing="10" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="models:City">
                                        <Border Background="{DynamicResource BgCard}"
                                                CornerRadius="12"
                                                Padding="20"
                                                BoxShadow="0 2 5 0 #05000000">
                                            <Grid ColumnDefinitions="Auto, *, Auto, Auto">

                                                <Border Grid.Column="0"
                                                        Width="50" Height="50"
                                                        CornerRadius="10"
                                                        Background="{DynamicResource BgInput}"
                                                        VerticalAlignment="Center">
                                                    <PathIcon
                                                        Data="M15,11V5L12,2L9,5V7H3V21H21V11H15M7,19H5V17H7V19M7,15H5V13H7V15M7,11H5V9H7V11M13,19H11V17H13V19M13,15H11V13H13V15M13,11H11V9H13V11M13,7H11V5H13V7M19,19H17V17H19V19M19,15H17V13H19V15"
                                                        Width="25" Height="25"
