<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:FlightsBookingX.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="using:FlightsBookingX.Views"
        xmlns:avalonia="clr-namespace:LoadingIndicators.Avalonia;assembly=LoadingIndicators.Avalonia"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        MinWidth="1280" MinHeight="720"
        x:Class="FlightsBookingX.Views.MainWindow"
        Icon="/Assets/avalonia-logo.ico"
        Title="FlightsBookingX"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        x:DataType="views:MainWindow">
        <views:MainView/>
</Window>
